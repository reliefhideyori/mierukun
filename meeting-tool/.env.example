# ── Gemini API（要約生成）──
# https://aistudio.google.com/app/apikey から取得
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Whisper ASR（ローカル文字起こし）──
# モデルサイズ: tiny / base / small / medium / large-v3
# medium 推奨（精度と速度のバランス）
WHISPER_MODEL=medium
# デバイス: cpu / cuda（NVIDIA GPU がある場合 cuda で高速化）
WHISPER_DEVICE=cpu

# ── 確定トリガー設定 ──
COOLDOWN_MS=1500
MIN_CHARS_FOR_UPDATE=25
